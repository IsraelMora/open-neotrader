generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// Un único usuario por instalación (local-first, no multiusuario)
model User {
  id                String   @id @default(uuid())
  username          String   @unique
  password_hash     String
  totp_secret       String?
  totp_enabled      Boolean  @default(false)
  backup_codes_hash String?
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("users")
}

// type: skill | universe | discipline | stack | provider
// verification: unverified | pending | verified | rejected
// skills, stack_plugins, symbols, config stored as JSON strings (SQLite has no JSON type)
model Plugin {
  id             String   @id
  name           String
  description    String?
  version        String
  type           String
  active         Boolean  @default(false)
  verification   String   @default("unverified")
  author         String?
  source_url     String?
  git_url        String?
  stack_plugins  String?
  skills         String?
  symbols        String?
  config         String?
  installed_path String?
  scan_result        String?  // JSON: ScanResult from F3-s1 static AST analysis; null = not yet scanned
  smoke_test_result  String?  // JSON: SmokeResult {ok,result,checks}; null = not yet smoke-tested
  reputation_score   Float?   // composite 0-100 from gate-ready pretest portfolios; null = unrated (F3-s3)
  reputation_detail  String?  // JSON: {portfolios_count, avg_sharpe, avg_return_pct, worst_dd_pct, computed_at}; null = unrated
  trust_score      Float?   // composite 0-100 (scan/smoke/reputation/votes, KV-weighted); null = no usable signal (F3-s4)
  content_checksum String?  // sha256 of manifest.toml+plugin.py+hooks/*.py at install; recompute+WARN on update (F3-s4)
  votes_net        Int      @default(0)  // reserved community net votes; inert (default 0 → neutral 50) until store→api sync (F3-s4)
  installed_at   DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("plugins")
}

model ConfigEntry {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("config")
}

model Portfolio {
  name      String   @id
  data      String
  updatedAt DateTime @updatedAt

  @@map("portfolio")
}

// Registro periódico del NAV (Net Asset Value) de la cartera
// Se escribe al final de cada ciclo del agente
model NavSnapshot {
  id           String   @id @default(uuid())
  ts           DateTime @default(now())
  cycle_id     String?                   // ciclo que generó el snapshot
  provider_id  String?                   // provider consultado
  strategy_id  String?                   // estrategia (perfil de config) dueña del snapshot
  equity       Float                     // valor total (cash + posiciones)
  cash         Float
  positions    String                    // JSON: Position[]
  total_pnl    Float    @default(0)
  meta         String?                   // JSON libre

  @@index([ts])
  @@index([strategy_id, ts])
  @@map("nav_snapshots")
}

// Estrategia = perfil nombrado con un bundle de configuración del ciclo.
// Varias pueden estar activas y competir; cada una acumula su propio NAV (NavSnapshot.strategy_id).
model Strategy {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  config      String                     // JSON: Record<string,string> (snapshot de claves KV del ciclo)
  active      Boolean  @default(false)    // participa en la competencia (se le corre el ciclo)
  mode        String   @default("test")   // "test" = data real, NO opera (mide) | "live" = opera de verdad
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Walk-forward gate (measurable-veto-shield): real-money execution requires the
  // CURRENTLY-APPLIED strategy to carry a recent "ROBUSTO" verdict here — see
  // TradeIntentService._checkWalkForwardGate(). Set by BacktestService.runWalkForward()
  // via StrategyService.recordWalkForward(); best-effort, never blocks the backtest itself.
  walk_forward_verdict     String?   // "ROBUSTO" | "SOBREAJUSTADO" | "INSUFICIENTE_DATOS" | null
  walk_forward_checked_at  DateTime?

  @@map("strategies")
}

// Alerta proactiva de riesgo generada por el AlertEngine
model AlertEntry {
  id         String   @id @default(uuid())
  ts         DateTime @default(now())
  type       String                      // "DRAWDOWN" | "FLASH_CRASH" | "CORRELATION_SPIKE" | "VOLUME_ANOMALY" | "MACRO_EVENT"
  severity   String                      // "LOW" | "MEDIUM" | "HIGH" | "CRITICAL"
  symbol     String?
  message    String
  meta       String?
  resolved   Boolean  @default(false)
  resolved_at DateTime?

  @@index([ts])
  @@index([type])
  @@map("alerts")
}

// Audit log — registro inmutable de decisiones del agente LLM
// Cada entrada representa un ciclo completo o una decisión individual
model AuditEntry {
  id              String   @id @default(uuid())
  ts              DateTime @default(now())
  cycle_id        String?               // UUID del ciclo al que pertenece
  event_type      String                // "cycle_start" | "cycle_complete" | "cycle_fail" | "signal" | "decision"
  plugin_id       String?               // plugin que generó el evento
  symbol          String?               // activo relacionado (si aplica)
  action          String?               // "long" | "exit" | "cancelled" | ...
  llm_text        String?               // texto de respuesta del LLM (truncado a 2000 chars)
  signals_count   Int?
  skills_read     String?               // JSON array de skills leídos
  skills_written  String?               // JSON array de skills escritos
  sandbox_ok      Boolean?
  error           String?
  meta            String?               // JSON libre para datos adicionales

  @@index([ts])
  @@index([cycle_id])
  @@index([event_type])
  @@map("audit_log")
}

// F6-s2: Long-term episodic memory — normal table only (episode_fts FTS5 virtual table is raw SQL, unmodeled).
model EpisodeMemory {
  id              String   @id
  ts              DateTime @default(now())
  cycle_id        String
  symbols         String
  regime_tags     String
  action_summary  String
  llm_rationale   String
  narrative       String
  outcome_pnl     Float?
  outcome_equity  Float?
  promoted        Int      @default(0)
  meta            String?

  @@index([cycle_id])
  @@index([ts])
  @@map("episode_memory")
}

// F6-s2 PR3: Curated lesson store — FIFO cap (max 30 rows) enforced by service at insert time.
model LessonMemory {
  id         String   @id
  ts         DateTime @default(now())
  text       String
  episode_id String?
  rationale  String?
  meta       String?

  @@index([ts])
  @@map("lesson_memory")
}

// ml-feature-extractor-s1: per-skill signal -> outcome capture for the on-device ML feature extractor.
// One row per (cycle_id, symbol). skill_vector is JSON [{plugin_id, action, confidence}].
// outcome_* are NULL at capture, backfilled by the NEXT snapshot (no lookahead).
model MlSignalRecord {
  id                String   @id
  ts                DateTime @default(now())
  cycle_id          String
  symbol            String
  skill_vector      String   // JSON: [{plugin_id, action, confidence}]
  action            String
  outcome_pnl       Float?
  outcome_equity    Float?
  active_skill_hash String
  meta              String?

  @@index([cycle_id])
  @@index([ts])
  @@map("ml_signal_record")
}

// Immutable veto decision ledger — one row per proposed signal per cycle, capturing
// what the veto layer decided (approved/blocked/modified) and enough context to
// reconstruct the counterfactual offline. cf_* fields are NULL at write time and
// backfilled later by a separate read-side analyzer (no lookahead), mirroring the
// outcome_pnl pattern on MlSignalRecord.
model VetoDecision {
  id                     String   @id @default(uuid())
  ts                     DateTime @default(now())
  cycle_id               String
  symbol                 String
  source_plugin          String
  signal_confidence      Float?
  proposed_action        String
  proposed_qty           Float
  verdict                String              // "approved" | "blocked" | "modified"
  approved_action        String?
  approved_qty           Float?
  discipline             String?
  rationale              String?
  ref_price              Float?
  regime_tags            String?
  portfolio_drawdown_pct Float?
  context_snapshot       String?             // JSON: proposed signal + market context for offline counterfactual reconstruction
  cf_pnl                 Float?              // counterfactual P&L — NULL at write, backfilled later by read-side analyzer (NO lookahead)
  cf_method              String?
  cf_evaluated_at        DateTime?

  @@index([cycle_id])
  @@index([symbol])
  @@index([ts])
  @@index([verdict])
  @@map("veto_decisions")
}

// HITL paper trade-execution layer.
// Records LLM trade decisions (TradeIntent) for human review before paper execution.
// Real-money execution IS possible but gated at the service layer, not disabled: the
// effective mode is derived from ExecutionPolicy (execution.real=true AND a
// broker_plugin_id AND a fresh ROBUSTO walk-forward verdict) — the `mode` column below
// is not the source of truth for whether an order ends up paper or real.
model TradeIntent {
  id            String    @id @default(cuid())
  cycle_id      String?
  symbol        String
  action        String                      // "long" | "short" | "exit" | "hold"
  confidence    Float
  rationale     String
  timeframe     String    @default("1d")
  mode          String    @default("paper") // stored value; effective mode is gated, see ExecutionPolicy above
  status        String    @default("pending") // "pending" | "approved" | "rejected" | "real_pending" | "executed" | "failed"
  created_at    DateTime  @default(now())
  decided_at    DateTime?
  decided_by    String?
  reject_reason String?
  fill_price    Float?
  quantity      Float?
  realized_pnl  Float?
  result_json   String?   // JSON: execution details

  realOrders    RealOrder[]

  @@index([status])
  @@index([created_at])
  @@index([cycle_id])
  @@map("trade_intents")
}

// Real-money order tracking — one row per broker order submitted for a TradeIntent
// executed in real mode. Tracks the full lifecycle (submit → poll → fill/error) so
// the fill price/qty used for accounting comes from the broker, not a pre-order quote.
//
// One-active-order-per-intent invariant (DB-enforced): at most one row per
// trade_intent_id may have a status outside {filled, canceled, rejected, expired,
// submit_failed} at any time. Prisma's DSL cannot express a partial unique index, so
// this is a raw-SQL constraint added in
// prisma/migrations/0016_real_order_active_intent_unique/migration.sql — see
// RealOrderService.submit() for the matching app-level guard + P2002 race handling.
model RealOrder {
  id                 String    @id @default(cuid())
  trade_intent_id    String
  broker_plugin_id   String
  client_order_id    String    @unique
  broker_order_id    String?
  symbol             String
  side               String
  order_type         String    @default("market")
  requested_qty      Float
  limit_price        Float?
  status             String    @default("pending_submit")
  filled_qty         Float     @default(0)
  filled_avg_price   Float?
  submitted_at       DateTime?
  filled_at          DateTime?
  last_reconciled_at DateTime?
  broker_raw_json    String?
  error              String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  tradeIntent        TradeIntent @relation(fields: [trade_intent_id], references: [id])
  @@index([status])
  @@index([broker_order_id])
  @@index([client_order_id])
  @@index([trade_intent_id])
  @@map("real_orders")
}

// Real-money position snapshot — one row per symbol, kept in sync with the broker's
// reported position (best-effort polling), replacing the paper-only Portfolio KV rows.
model RealPosition {
  symbol            String    @id
  broker_plugin_id  String
  qty               Float
  avg_entry         Float
  market_value      Float
  unrealized_pnl    Float
  side              String
  last_synced_at    DateTime  @updatedAt
  @@map("real_positions")
}

// Real-money NAV history — periodic snapshots of broker account equity/cash/buying
// power, replacing the paper-only NavSnapshot for the real-money accounting path.
model RealNavSnapshot {
  id                String    @id @default(uuid())
  ts                DateTime  @default(now())
  broker_plugin_id  String
  equity            Float
  cash              Float
  buying_power      Float
  positions         String
  total_pnl         Float     @default(0)
  hwm               Float
  source            String    @default("poll")
  meta              String?
  @@index([ts])
  @@index([broker_plugin_id, ts])
  @@map("real_nav_snapshots")
}

// Cartera virtual de pretest — permite probar configuraciones distintas antes de usar dinero real
// Cada pretest es independiente: tiene sus propios plugins activos, config y estado de cartera virtual
model PretestPortfolio {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  initial_capital Float    @default(10000)
  plugin_ids      String                    // JSON: string[] — plugins a ejecutar en este pretest
  plugin_configs  String?                   // JSON: Record<plugin_id, config_override>
  state           String                    // JSON: PretestState (equity, cash, positions, trades)
  run_count       Int      @default(0)
  last_run_at     DateTime?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("pretest_portfolios")
}
