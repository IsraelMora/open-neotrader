[
  {
    "name": "compute_zscore",
    "description": "Calcula el Z-Score del precio actual respecto a su media histórica de N días.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "prices": { "type": "array", "items": { "type": "number" }, "description": "Precios de cierre, más antiguo primero" },
        "lookback": { "type": "integer", "description": "Días para calcular la media y std (default 20)" }
      },
      "required": ["symbol", "prices"]
    }
  },
  {
    "name": "detect_mean_reversion",
    "description": "Analiza una serie de precios y retorna señal de reversión si el Z-Score supera el umbral.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "prices": { "type": "array", "items": { "type": "number" } },
        "lookback": { "type": "integer" },
        "entry_zscore": { "type": "number", "description": "Umbral de entrada (default 2.0)" },
        "exit_zscore": { "type": "number", "description": "Umbral de salida (default 0.5)" },
        "current_signal": { "type": "string", "enum": ["long", "short"], "description": "Señal activa actual (si hay posición)" }
      },
      "required": ["symbol", "prices"]
    }
  }
]
