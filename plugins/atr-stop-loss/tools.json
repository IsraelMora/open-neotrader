[
  {
    "name": "calculate_atr_stop",
    "description": "Calcula stop loss dinámico basado en ATR para una nueva señal de entrada. SIEMPRE llama este tool antes de ejecutar una operación para obtener el stop loss adaptativo a la volatilidad actual del activo.",
    "input_schema": {
      "type": "object",
      "properties": {
        "symbol":         { "type": "string", "description": "Ticker del activo" },
        "entry_price":    { "type": "number", "description": "Precio de entrada planificado" },
        "direction":      { "type": "string", "enum": ["long", "short"], "description": "Dirección de la operación" },
        "closes":         { "type": "array", "items": { "type": "number" }, "description": "Serie de precios de cierre (cronológico)" },
        "highs":          { "type": "array", "items": { "type": "number" }, "description": "Serie de precios máximos" },
        "lows":           { "type": "array", "items": { "type": "number" }, "description": "Serie de precios mínimos" }
      },
      "required": ["symbol", "entry_price", "closes"]
    }
  },
  {
    "name": "update_trailing_stop",
    "description": "Actualiza el trailing stop de una posición abierta. Llama en cada ciclo para cada posición en cartera. El stop solo se mueve a favor de la posición (nunca en contra).",
    "input_schema": {
      "type": "object",
      "properties": {
        "symbol":          { "type": "string", "description": "Ticker del activo" },
        "entry_price":     { "type": "number", "description": "Precio de entrada original" },
        "highest_price":   { "type": "number", "description": "Precio más alto alcanzado desde la entrada (para long)" },
        "direction":       { "type": "string", "enum": ["long", "short"], "default": "long" },
        "closes":          { "type": "array", "items": { "type": "number" } },
        "highs":           { "type": "array", "items": { "type": "number" } },
        "lows":            { "type": "array", "items": { "type": "number" } }
      },
      "required": ["symbol", "entry_price", "highest_price", "closes"]
    }
  }
]
