[
  {
    "name": "inject_backtest_signals",
    "description": "Inyecta señales históricas para el backtest. Cada señal debe tener: symbol, action (long|short|exit), date (YYYY-MM-DD), y opcionalmente price, confidence.",
    "parameters": {
      "type": "object",
      "properties": {
        "signals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "symbol":     { "type": "string" },
              "action":     { "type": "string", "enum": ["long", "short", "exit"] },
              "date":       { "type": "string", "description": "YYYY-MM-DD" },
              "price":      { "type": "number", "description": "Precio de entrada/salida (opcional)" },
              "confidence": { "type": "number", "description": "0.0-1.0" }
            },
            "required": ["symbol", "action", "date"]
          },
          "description": "Lista de señales históricas"
        }
      },
      "required": ["signals"]
    }
  },
  {
    "name": "inject_backtest_prices",
    "description": "Inyecta precios históricos OHLCV para el backtest. Formato: {symbol: [{date, open, high, low, close, volume}]}",
    "parameters": {
      "type": "object",
      "properties": {
        "prices": {
          "type": "object",
          "description": "Diccionario de precios: {AAPL: [{date, open, high, low, close, volume}], ...}",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date":   { "type": "string" },
                "open":   { "type": "number" },
                "high":   { "type": "number" },
                "low":    { "type": "number" },
                "close":  { "type": "number" },
                "volume": { "type": "number" }
              },
              "required": ["date", "close"]
            }
          }
        }
      },
      "required": ["prices"]
    }
  },
  {
    "name": "run_backtest",
    "description": "Ejecuta el backtest con las señales y precios previamente inyectados. Devuelve métricas de rendimiento: Sharpe, max drawdown, win rate, profit factor, curva de equity.",
    "parameters": {
      "type": "object",
      "properties": {
        "initial_capital": {
          "type": "number",
          "description": "Capital inicial en USD. Default: 10000",
          "default": 10000
        },
        "commission_pct": {
          "type": "number",
          "description": "Comisión por operación como fracción (0.001 = 0.1%). Default: 0.001",
          "default": 0.001
        }
      },
      "required": []
    }
  },
  {
    "name": "compare_strategies",
    "description": "Compara los resultados de múltiples backtests para identificar la estrategia óptima.",
    "parameters": {
      "type": "object",
      "properties": {
        "strategy_names": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Nombres de las estrategias a comparar"
        }
      },
      "required": ["strategy_names"]
    }
  },
  {
    "name": "run_walk_forward",
    "description": "Ejecuta validación walk-forward out-of-sample (Pardo 2008) usando el pipeline real de generación de señales + motor de backtesting. Divide el historial en N ventanas anchored IS/OOS, ejecuta el backtest en cada una, calcula el ratio de robustez (Sharpe_OOS / Sharpe_IS) y devuelve veredicto ROBUSTO | SOBREAJUSTADO | INSUFICIENTE_DATOS. Detecta overfitting cuando el Sharpe OOS cae por debajo del 50% del IS.",
    "parameters": {
      "type": "object",
      "properties": {
        "strategy_id": {
          "type": "string",
          "description": "ID de la estrategia: 'trend-following', 'mean-reversion' o 'session-breakout'"
        },
        "prices": {
          "type": "object",
          "description": "Precios OHLCV por símbolo: {SYMBOL: [{date, open, high, low, close, volume}]}",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date":   { "type": "string" },
                "open":   { "type": "number" },
                "high":   { "type": "number" },
                "low":    { "type": "number" },
                "close":  { "type": "number" },
                "volume": { "type": "number" }
              },
              "required": ["date", "close"]
            }
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "n_windows":      { "type": "integer", "description": "Número de ventanas walk-forward (default 5)" },
            "in_sample_pct":  { "type": "number",  "description": "Fracción IS por ventana (default 0.7)" },
            "min_trades":     { "type": "integer", "description": "Mínimo de trades OOS para ventana válida (default 10)" },
            "commission_pct": { "type": "number",  "description": "Comisión por operación (default 0.001)" },
            "slippage_pct":   { "type": "number",  "description": "Slippage estimado (default 0.0005)" }
          }
        }
      },
      "required": ["strategy_id", "prices"]
    }
  }
]
