{
  "tools": [
    {
      "name": "scan_funding_opportunities",
      "description": "Escanea una lista de activos crypto y detecta oportunidades de arbitraje de funding rate (delta-neutral). Devuelve oportunidades ordenadas por APR con clasificación de calidad.",
      "input_schema": {
        "type": "object",
        "required": ["symbols_data"],
        "properties": {
          "symbols_data": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["symbol", "funding_rate_8h"],
              "properties": {
                "symbol":            { "type": "string" },
                "funding_rate_8h":   { "type": "number", "description": "Tasa de funding del período de 8h. Positivo = perp caro (long spot / short perp). Negativo = perp barato (short spot / long perp)." },
                "open_interest_usd": { "type": "number", "description": "Open interest del contrato perpetuo en USD" }
              }
            }
          },
          "config": { "type": "object" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "total_scanned":        { "type": "integer" },
          "opportunities_found":  { "type": "integer" },
          "best_apr":             { "type": "number" },
          "opportunities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "symbol":              { "type": "string" },
                "funding_rate_8h":     { "type": "number" },
                "funding_apr":         { "type": "number" },
                "direction":           { "type": "string" },
                "signal":              { "type": "integer" },
                "estimated_daily_pct": { "type": "number" },
                "quality":             { "type": "string", "enum": ["excellent", "good", "marginal", "avoid"] },
                "reason":              { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "name": "analyze_funding_opportunity",
      "description": "Analiza un único activo crypto para oportunidad de arbitraje de funding rate.",
      "input_schema": {
        "type": "object",
        "required": ["symbol", "funding_rate_8h"],
        "properties": {
          "symbol":            { "type": "string" },
          "funding_rate_8h":   { "type": "number" },
          "open_interest_usd": { "type": "number" },
          "config":            { "type": "object" }
        }
      }
    }
  ]
}
