# NeuroTrader — Variables de entorno
# Copia a .env y rellena los valores. NUNCA hagas commit de .env.
#
# Lo MÍNIMO para arrancar: JWT_SECRET + un LLM (ver sección LLM). Las API keys de
# LLM y brokers se pueden cargar después por la API /credentials (recomendado; persisten
# en el volumen). El resto de la operación se configura por API — ver README "Configuración".

# ── NestJS API ───────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
API_HOST=0.0.0.0

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-valor-aleatorio-largo-minimo-64-bytes
JWT_EXPIRES_IN=7d
TOTP_ISSUER=NeuroTrader

# Base de datos SQLite (en Docker: volumen persistente)
DATABASE_URL=file:/data/neurotrader.db
# Archivo .env persistente donde /credentials guarda las API keys (en el volumen)
DOTENV_PATH=/data/.env

# ── Sandbox Python (subprocess, SIN red) ──────────────────────────────────────
SANDBOX_RUNNER_PATH=/sandbox/runner.py
PLUGINS_DIR=/plugins
PLUGIN_SDK_PATH=/opt/plugin-sdk
SANDBOX_TIMEOUT_MS=60000

# ── LLM (elegí UN backend; keys mejor por /api/credentials) ────────────────────
# LLM_BACKEND=openai es el cliente GENÉRICO OpenAI-compatible: funciona con
# cualquier provider que exponga un endpoint /chat/completions estilo OpenAI.
# Configuralo con 3 vars genéricas: LLM_BASE_URL + LLM_API_KEY + LLM_MODEL.
# (Compat hacia atrás: si LLM_BASE_URL/LLM_API_KEY no están seteadas, cae a
# OPENAI_BASE_URL/OPENAI_API_KEY — no rompe configs existentes.)
#
# Ejemplos (elegí uno, descomentá y completá):
#   OpenRouter (incluye modelos FREE con tool-calling; recomendado):
#     LLM_BASE_URL=https://openrouter.ai/api/v1
#     LLM_API_KEY=sk-or-v1-...
#     LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
#   Gemini (vía su endpoint OpenAI-compatible):
#     LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#     LLM_API_KEY=...
#     LLM_MODEL=gemini-2.0-flash
#   OpenAI:
#     LLM_BASE_URL=https://api.openai.com/v1
#     LLM_API_KEY=sk-...
#     LLM_MODEL=gpt-4o-mini
#   Ollama (local, sin key real):
#     LLM_BASE_URL=http://localhost:11434/v1
#     LLM_API_KEY=ollama
#     LLM_MODEL=llama3.1
#
# Backend alternativo (no genérico): LLM_BACKEND=anthropic · ANTHROPIC_API_KEY=sk-ant-... · LLM_MODEL=claude-sonnet-4-6
LLM_BACKEND=openai
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
# OPENAI_BASE_URL/OPENAI_API_KEY — legacy, mantenidas por compat hacia atrás
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080

# ── Brokers / datos (cargar vía POST /api/credentials, NO acá) ─────────────────
# Datos: yahoo-finance-provider (gratis). Ejecución: alpaca-provider
# (ALPACA_API_KEY_ID/ALPACA_API_SECRET_KEY). Todas por /api/credentials (persisten).

# ── Notificaciones (opcional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
