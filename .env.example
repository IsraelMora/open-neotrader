# NeuroTrader — Variables de entorno
# Copia a .env y rellena los valores. NUNCA hagas commit de .env.
# Stack: NestJS (api :3000) + Astro/nginx (web :8080) + Python sandbox (subprocess)

# ── NestJS API ───────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
API_HOST=127.0.0.1   # 0.0.0.0 en producción (se auto-detecta por NODE_ENV)

# JWT — genera con: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=cambia-esto-por-un-valor-aleatorio-largo-minimo-64-bytes
JWT_EXPIRES_IN=8h

# Base de datos SQLite
DB_PATH=./neurotrader.db   # en Docker: /data/neurotrader.db (volumen persistente)

# ── Sandbox Python (subprocess) ───────────────────────────────────────────────
SANDBOX_RUNNER_PATH=../../apps/sandbox/runner.py   # ruta al runner (relativa a apps/api/)
PLUGINS_DIR=../../plugins                           # directorio de plugins instalados
PLUGIN_SDK_PATH=../../packages/plugin-sdk           # para PYTHONPATH
SANDBOX_TIMEOUT_MS=60000
SANDBOX_CPU_SECONDS=60       # límite de CPU por invocación del sandbox (segundos)
SANDBOX_MEM_MB=512           # límite de RAM por invocación del sandbox (MB)

# ── LLM ──────────────────────────────────────────────────────────────────────
# Al menos ANTHROPIC_API_KEY para usar ciclos con LLM (dry_run no la necesita)
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
OPENAI_API_KEY=

LLM_MODEL=claude-haiku-4-5-20251001   # haiku = económico; claude-sonnet-4-6 = más calidad

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080   # separar por comas si hay múltiples

# ── Brokers (opcionales — las keys van mejor en la UI via Credentials) ───────
# No ponerlas aquí; usar POST /api/credentials desde la UI para mayor seguridad

# ── Notificaciones (opcionales) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Tienda de plugins (read-only) ─────────────────────────────────────────────
STORE_URL=https://store.neurotrader.app

# ── Panel (opcional — solo si el panel sale de loopback) ─────────────────────
# PANEL_TOKEN=token-secreto-para-autenticacion
